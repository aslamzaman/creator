                                first: 50, 
                                after: $after,
                                filter: $episodeCreditsFilter
                                sort: {by: RELEASE_DATE order: ASC}
                            ) {
                                pageInfo {
                                    endCursor
                                    hasNextPage
                                }
                                edges {
                                    node {
                                        attributes {
                                            text
                                        }
                                        ... on Cast {
                                            title {
                                                ...EpisodeBottomSheetTitleMetadata
                                            }
                                            characters {
                                                name
                                            }
                                        }
                                    }
                                }
                            }
                            nav: episodeCredits(
                                first: 0
                            ) {
                                ...CastEpisodeBottomSheetNav
                            }
                        }
                    }
                }
            }
        }
    }
    ${o}
    ${n}
